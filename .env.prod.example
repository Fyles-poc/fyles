# ============================================================
# Fyles — Variables d'environnement de production
# ============================================================
# 1. Copie ce fichier : cp .env.prod.example .env.prod
# 2. Remplis chaque valeur
# 3. NE JAMAIS committer .env.prod dans git
# ============================================================

# IP publique du VPS (sans http://, sans slash final)
SERVER_IP=1.2.3.4

# Clé secrète JWT — génère avec : openssl rand -hex 32
JWT_SECRET=remplace-par-une-chaine-aleatoire-de-64-caracteres

# Clé API Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Credentials MinIO (stockage fichiers)
# Choisis des valeurs robustes — elles servent aussi de mot de passe admin MinIO
MINIO_ACCESS_KEY=fyles-minio-user
MINIO_SECRET_KEY=remplace-par-un-mot-de-passe-fort
